{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "voice-agent",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2026-05-01",
	"compatibility_flags": ["nodejs_als"],
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"routes": [
		{
			"pattern": "voice.stixman.co",
			"custom_domain": true
		}
	]
}
